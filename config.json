{
    "initial_directory": "D:/jiangweipeng/trae_code/个人文件/图片sample",
    "low_memory_mode": {
        "enabled": true,
        "description": "低内存设备优化模式。启用后会降低内存占用但可能增加处理时间。适用于内存≤8GB的设备。启用后建议: 1)embedding.model_name改为L6版本 2)ocr_max_image_width降至1000 3)enable_mkldnn设为false",
        "periodic_memory_cleanup": {
            "enabled": true,
            "file_interval": 50,
            "description_enabled": "是否启用定期内存清理。启用后每处理N个文件执行一次积极内存清理，降低内存占用但可能略微增加处理时间",
            "description_file_interval": "内存清理间隔（处理多少个文件后清理一次）。推荐值: 5-10，值越小内存越低但速度越慢"
        }
    },
    "classification": {
        "method": "similarity",
        "description": "分类方法: 'similarity' 使用语义相似度分类, 'clustering' 使用语义聚类分类, 'llm' 使用本地LLM模型分类"
    },
    "query": {
        "top_k": 10,
        "top_m": 5,
        "description": "语义搜索参数: top_k为检索的语义块数量, top_m为返回的文件数量"
    },
    "logging": {
        "enabled": true,
        "level": "INFO",
        "description": "日志配置: enabled为是否启用日志记录, level为日志级别(DEBUG/INFO/WARNING/ERROR)"
    },
    "performance": {
        "enabled": true,
        "log_file": "logs/performance.log",
        "log_interval_seconds": 5,
        "track_memory": true,
        "track_latency": true,
        "track_cpu": false,
        "description": "性能监控配置: enabled为是否启用性能监控, log_file为性能日志文件路径, track_memory为是否监控内存, track_latency为是否监控时延"
    },
    "similarity_weights": {
        "vector_weight": 0.35,
        "bm25_weight": 0.3,
        "keyword_weight": 0.35,
        "time_weight": 0.0,
        "location_weight": 0.0,
        "description": "语义相似度各子相似度权重，总和应为1.0"
    },
