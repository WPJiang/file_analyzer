    "bm25": {
        "k1": 1.5,
        "b": 0.75,
        "description": "BM25算法参数"
    },
    "clustering": {
        "distance_metric": "cosine",
        "description": "聚类距离度量: 'cosine', 'euclidean', 'manhattan'"
    },
    "parsing": {
        "mode": 1,
        "description": "解析模式: 1=轻量解析, 2=深度解析",
        "light_mode_max_length": 256,
        "description_max_length": "轻量解析时文本内容的最大长度",
        "pdf_image_mode": "page_render",
        "description_pdf_image_mode": "PDF图片提取模式: 'embedded'=提取内嵌图片, 'page_render'=将每页渲染为图片保存到磁盘",
        "pdf_image_output_dir": "cache/pdf_images",
        "description_pdf_image_output_dir": "PDF页面渲染图片的输出目录(相对于项目根目录)",
        "pdf_render_dpi": 100,
        "description_pdf_render_dpi": "PDF渲染DPI(100-150推荐)，越低越快但OCR准确度可能降低"
    },
    "semantic_text_fields": {
        "vector": [
            "semantic_filename",
            "text_description"
        ],
        "bm25": [
            "semantic_filename",
            "text_description"
        ],
        "description": "语义块文本拼接字段配置。vector: 用于生成语义向量的字段列表; bm25: 用于BM25相似度计算的字段列表。可选字段: semantic_filename(语义文件名), text_description(文本描述), keywords(关键词列表)。字段按列表顺序拼接，keywords会展开为空格分隔的关键词列表"
    },
    "semantic_representation": {
        "image": {
            "use_ocr": true,
            "description": "图片文本提取方式: true=使用OCR, false=使用基础描述",
            "ocr_model": "paddleocr",
            "description_ocr_model": "OCR模型: paddleocr(轻量模型)",
            "ocr_model_path": "",
            "description_ocr_model_path": "OCR模型本地路径（留空则自动查找models/paddleocr目录）。支持两种加载模式：1)本地加载-将OCR模型放到models/paddleocr目录下自动加载；2)联网下载-首次运行时自动下载并保存到本地",
            "ocr_max_image_width": 1500,
            "description_ocr_max_image_width": "OCR前图片最大宽度(像素)，超过此宽度会缩小以加速OCR，0=不缩放",
            "enable_mkldnn": true,
            "description_enable_mkldnn": "是否启用MKL-DNN优化加速OCR。启用后: OCR速度提升约30%%，内存占用略增；禁用后: OCR较慢，内存占用较低"
        },
        "embedding": {
            "type": "sentence_transformer",
            "model_name": "paraphrase-multilingual-MiniLM-L12-v2",
            "description_model_name": "Embedding模型选择。可选: paraphrase-multilingual-MiniLM-L12-v2(420MB,平衡性能), paraphrase-multilingual-MiniLM-L6-v2(110MB,更轻量更快,推荐低内存设备)"
        },
        "keyword": {
            "method": "jieba",
            "top_k": 10
        },
        "description": {
            "max_length": 512
        },
        "filename_semantic": {
            "enabled": true,
            "description": "文件名语义分析配置。启用后会判断文件名是否包含有效语义，随机序列、时间戳等无意义文件名将被过滤",
            "include_in_vector": true,
            "description_include_in_vector": "是否在向量生成时包含文件名（当文件名有意义时）",
            "include_in_bm25": true,
            "description_include_in_bm25": "是否在BM25计算时包含文件名（当文件名有意义时）",
            "min_meaningful_chars": 3,
            "description_min_meaningful_chars": "最小有意义字符数",
            "chinese_ratio_threshold": 0.3,
            "description_chinese_ratio_threshold": "中文字符比例阈值，超过此值认为有意义"
        }
    },
    "llm": {
        "type": "cloud",
        "description": "LLM类型: 'cloud'使用云侧大模型, 'ollama'使用本地Ollama服务, 'local_llama'使用本地llama.cpp服务器。默认使用本地llama.cpp服务器",
        "cloud": {
            "config_file": "api_config.json",
            "description_config_file": "云侧API配置文件路径，包含api_key、base_url、model等配置。请复制api_config_example.json并重命名为api_config.json，然后填入实际的API密钥"
        },
        "ollama": {
            "base_url": "http://localhost:11434",
            "description_base_url": "Ollama服务地址",
            "model": "qwen3.5:0.8b",
            "description_model": "Ollama模型名称",
            "keep_alive": "10m",
            "description_keep_alive": "模型在内存中保持的时间，避免每次调用重新加载"
        },
        "local_llama": {
            "base_url": "http://127.0.0.1:11435/v1",
            "description_base_url": "本地llama.cpp服务器地址。通过llama-server.exe启动，例如: ./llama-server.exe -m model.gguf -c 2048 --host 0.0.0.0 --port 11435",
            "model": "qwen3.5-0.8b",
            "description_model": "模型名称，与启动时指定的模型对应",
            "timeout": 300,
            "description_timeout": "API调用超时时间（秒），本地模型可能较慢",
            "max_tokens": 8192,
            "description_max_tokens": "最大生成token数",
            "temperature": 0.7,
            "description_temperature": "生成温度，0-1之间，越高越随机"
        }
    },
    "image_processing": {
        "max_dimension": 448,
        "description_max_dimension": "图片缩放最大尺寸（像素），保持长宽比。用于图片Caption生成前的预处理。推荐值: 224(快速), 448(平衡), 896(高质量)"
    }
